# ====================== PERFIL DE LLM (interruptor LGPD) ======================
# "ollama"     -> LLM local on-prem, nada vaza (producao / LGPD)
# "openrouter" -> API externa, so DEMO com dados sinteticos do case
LLM_PROVIDER=ollama

# --- perfil local (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b          # 3b p/ CPU (laptop); 7b/14b p/ estacao com GPU 16GB

# --- perfil cloud (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# ====================== BANCO (camada trocavel) ======================
# vazio        -> SQLite local em data/fiesc.db (on-prem)
# postgres://  -> Supabase / Postgres (cloud, persiste a demo)
DATABASE_URL=

# ====================== Telegram (frente operador) ======================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
