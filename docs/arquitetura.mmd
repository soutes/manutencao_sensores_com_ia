    LLM_GW -->|"LLM_PROVIDER=openrouter"| OR
    OLL -->|"prescrição"| BE
    OR -->|"prescrição"| BE

    BE -->|"grava evento + status"| TABS
    TABS --- SQLITE
    TABS --- SUPA

    %% ── Alimentação dos índices ───────────────────────────────────
    PDF -->|"OCR + chunking\n(build_all.py)"| RAG
    CSV -->|"fit scaler + KNN\n(build_all.py)"| SIM

